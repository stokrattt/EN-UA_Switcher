<Window x:Class="Switcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="EN-UA Switcher — Settings"
        Width="680"
        Height="620"
        MinWidth="620"
        MinHeight="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource DarkWindowStyle}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="12"
                Margin="0,0,0,10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="EN-UA Switcher"
                           Tag="App.Name"
                           Style="{StaticResource WindowTitleStyle}"
                           VerticalAlignment="Center" />
                <Border Style="{StaticResource PillBorderStyle}"
                        Margin="12,0,0,0"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Style="{StaticResource StatusDotGreen}" />
                        <TextBlock x:Name="StatusText"
                                   Text="Engine running — Safe mode only"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
            <TabControl Margin="0"
                        Padding="12,12,12,6"
                        Background="Transparent"
                        BorderThickness="0">

                <TabItem Header="General" Tag="Tab.General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="AUTOMATION" Tag="Settings.AutomationEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="General" Tag="Settings.GeneralHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="Settings.GeneralDescription"
                                               Text="Choose how EN-UA Switcher reacts while you type. Safe hotkeys remain available even with Auto Mode disabled."
                                               Margin="0,0,0,8" />

                                    <CheckBox x:Name="ChkAutoMode"
                                              ToolTip="Tooltip.Settings.EnableAutoMode">
                                        <TextBlock Text="Enable Auto Mode (automatic correction after Space / Enter / Tab)"
                                                   Tag="Settings.EnableAutoMode"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkSafeOnlyAutoMode"
                                              Margin="0,6,0,0"
                                              ToolTip="Tooltip.Settings.SafeOnlyAutoMode">
                                        <TextBlock Text="Safe-only browser auto-replace (requires Auto Mode)"
                                                   Tag="Settings.SafeOnlyAutoMode"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkElectronUiaPath"
                                              Margin="0,6,0,0"
                                              ToolTip="Tooltip.Settings.ElectronUiaPath">
                                        <TextBlock Text="Electron app path: UIA read + Backspace replace (requires Auto Mode)"
                                                   Tag="Settings.ElectronUiaPath"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkDisableBrowserAddressBarAutoCorrection"
                                              Margin="0,6,0,0"
                                              ToolTip="Tooltip.Settings.AddressBarSkip">
                                        <TextBlock Text="Skip Auto Mode in browser address bars"
                                                   Tag="Settings.AddressBarSkip"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>

                                    <Separator />

                                    <TextBlock Text="Delimiter keys" Tag="Settings.DelimiterKeys" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="Settings.DelimiterDescription"
                                               Text="Choose which keys trigger auto-correction after a word."
                                               Margin="0,0,0,8" />
                                    <CheckBox x:Name="ChkCorrectOnSpace"
                                              Content="Correct on Space"
                                              Tag="Settings.CorrectOnSpace"
                                              ToolTip="Tooltip.Settings.CorrectOnSpace" />
                                    <CheckBox x:Name="ChkCorrectOnEnter"
                                              Content="Correct on Enter"
                                              Tag="Settings.CorrectOnEnter"
                                              ToolTip="Tooltip.Settings.CorrectOnEnter" />
                                    <CheckBox x:Name="ChkCorrectOnTab"
                                              Content="Correct on Tab"
                                              Tag="Settings.CorrectOnTab"
                                              ToolTip="Tooltip.Settings.CorrectOnTab" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="CONTROL" Tag="Settings.ControlEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Cancel and undo" Tag="Settings.CancelUndoHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="Settings.CancelUndoDescription"
                                               Text="These options protect the current word buffer and let you roll back an accidental auto-correction."
                                               Margin="0,0,0,8" />

                                    <CheckBox x:Name="ChkCancelOnBackspace"
                                              ToolTip="Tooltip.Settings.CancelOnBackspace">
                                        <TextBlock Text="Cancel on Backspace" Tag="Settings.CancelOnBackspace" TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkCancelOnLeftArrow"
                                              ToolTip="Tooltip.Settings.CancelOnLeftArrow">
                                        <TextBlock Text="Cancel on Left Arrow" Tag="Settings.CancelOnLeftArrow" TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkUndoOnBackspace"
                                              ToolTip="Tooltip.Settings.UndoOnBackspace">
                                        <TextBlock Text="Undo correction on Backspace" Tag="Settings.UndoOnBackspace" TextWrapping="Wrap" />
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="APP" Tag="Settings.AppEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Startup and diagnostics" Tag="Settings.StartupDiagnosticsHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="Settings.StartupDiagnosticsDescription"
                                               Text="A few practical toggles for startup behavior and troubleshooting."
                                               Margin="0,0,0,8" />

                                    <TextBlock Text="Interface language"
                                               Tag="Settings.InterfaceLanguageHeader"
                                               Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="Settings.InterfaceLanguageDescription"
                                               Text="Auto follows the Windows display language; manual choices are saved."
                                               Margin="0,0,0,8" />
                                    <ComboBox x:Name="CmbInterfaceLanguage"
                                              Width="220"
                                              HorizontalAlignment="Left"
                                              SelectedValuePath="Tag"
                                              SelectionChanged="CmbInterfaceLanguage_SelectionChanged"
                                              Margin="0,0,0,12">
                                        <ComboBoxItem Tag="Auto" Content="Auto" />
                                        <ComboBoxItem Tag="uk" Content="Українська" />
                                        <ComboBoxItem Tag="en" Content="English" />
                                    </ComboBox>

                                    <CheckBox x:Name="ChkRunAtStartup"
                                              Content="Run at Windows startup"
                                              Tag="Settings.RunAtStartup"
                                              ToolTip="Tooltip.Settings.RunAtStartup" />
                                    <CheckBox x:Name="ChkStartMinimized"
                                              Content="Start minimized to system tray"
                                              Tag="Settings.StartMinimized" />
                                    <CheckBox x:Name="ChkDiagnostics"
                                              Content="Enable diagnostics logging"
                                              Tag="Settings.Diagnostics" />
                                    <CheckBox x:Name="ChkSelectorDiagnosticsExport"
                                              Margin="0,6,0,0"
                                              ToolTip="Tooltip.Settings.SelectorExport">
                                        <TextBlock Text="Export structured selector examples (opt-in ML diagnostics)"
                                                   Tag="Settings.SelectorExport"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkLearnedSelectorGate"
                                              Margin="0,6,0,0"
                                              ToolTip="Tooltip.Settings.LearnedSelectorGate">
                                        <TextBlock Text="Enable learned selector rejection gate (experimental)"
                                                   Tag="Settings.LearnedSelectorGate"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Margin="32,6,0,0"
                                               Tag="Settings.StandardDiagnostics"
                                               Text="Standard diagnostics stay redacted. Structured selector export writes examples only when you enable it." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Hotkeys" Tag="Tab.Hotkeys">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="SAFE MODE" Tag="Hotkeys.SafeModeEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Global hotkeys" Tag="Hotkeys.GlobalHotkeysHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="Hotkeys.Description"
                                               Text="These hotkeys act on the focused text target even if Auto Mode is turned off."
                                               Margin="0,0,0,8" />
                                    <TextBlock x:Name="TxtHotkeyStatus"
                                               Style="{StaticResource MutedTextStyle}"
                                               Tag="Hotkeys.StatusChecking"
                                               Text="Hotkeys status: checking..."
                                               Margin="0,0,0,14" />

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Fix last word" Tag="Hotkeys.FixLastWord" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 x:Name="TxtLastWordHotkey"
                                                 IsReadOnly="True"
                                                 Tag="Hotkeys.LastWordHotkeyField"
                                                 ToolTip="Tooltip.Hotkeys.LastWordHotkeyField"
                                                 PreviewKeyDown="TxtHotkey_PreviewKeyDown" />
                                        <Button Grid.Column="2"
                                                Content="Change"
                                                Tag="Hotkeys.ChangeShortcut"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                ToolTip="Tooltip.Hotkeys.ChangeShortcut"
                                                Click="BtnChangeLastWordHotkey_Click" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Fix selected text" Tag="Hotkeys.FixSelectedText" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 x:Name="TxtSelectionHotkey"
                                                 IsReadOnly="True"
                                                 Tag="Hotkeys.SelectionHotkeyField"
                                                 ToolTip="Tooltip.Hotkeys.SelectionHotkeyField"
                                                 PreviewKeyDown="TxtHotkey_PreviewKeyDown" />
                                        <Button Grid.Column="2"
                                                Content="Change"
                                                Tag="Hotkeys.ChangeShortcut"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                ToolTip="Tooltip.Hotkeys.ChangeShortcut"
                                                Click="BtnChangeSelectionHotkey_Click" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="NOTE" Tag="Hotkeys.NoteEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Current behavior" Tag="Hotkeys.CurrentBehaviorHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="Hotkeys.Note"
                                               Text="Click a hotkey field and press your desired combination (modifier + letter/key). At least one of Ctrl, Shift, or Alt is required. Changes take effect after Save." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Exclusions" Tag="Tab.Exclusions">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="SCOPE" Tag="Exclusions.ScopeEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock Text="Excluded processes" Tag="Exclusions.ProcessesHeader" Style="{StaticResource SectionHeaderStyle}" />
                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                   Tag="Exclusions.ProcessesDescription"
                                                    Text="Choose a running app from the list or type a process name manually. Use names without .exe."
                                                   Margin="0,0,0,6" />
                                    </StackPanel>

                                    <Grid Grid.Row="1" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox x:Name="CmbRunningProcesses"
                                                  Grid.Column="0"
                                                  Margin="0,0,10,0"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="True"
                                                  StaysOpenOnEdit="True"
                                                  ToolTip="Tooltip.Exclusions.RunningProcesses"
                                                  GotKeyboardFocus="CmbRunningProcesses_GotKeyboardFocus"
                                                  PreviewMouseLeftButtonDown="CmbRunningProcesses_PreviewMouseLeftButtonDown"
                                                  PreviewMouseWheel="NestedScrollHost_PreviewMouseWheel" />
                                        <Button Grid.Column="1"
                                                Content="Add Selected"
                                                Tag="Exclusions.AddSelected"
                                                Click="BtnAddSuggestedExclusion_Click"
                                                Margin="0,0,8,0" />
                                        <Button Grid.Column="2"
                                                Content="Refresh"
                                                Tag="Exclusions.Refresh"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnRefreshProcesses_Click" />
                                    </Grid>

                                    <ListBox x:Name="LstExclusions"
                                             Grid.Row="2"
                                             Height="96"
                                             Margin="0,0,0,8"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             PreviewMouseWheel="NestedScrollHost_PreviewMouseWheel"
                                             MouseDoubleClick="LstExclusions_MouseDoubleClick" />

                                    <TextBlock Grid.Row="3"
                                               Style="{StaticResource MutedTextStyle}"
                                               Tag="Exclusions.ManualProcess"
                                               Text="Manual add: type a name like chrome, telegram, element or codex and press Enter."
                                               Margin="0,0,0,8" />

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="TxtNewExclusion"
                                                 Grid.Column="0"
                                                 Margin="0,0,10,0"
                                                 ToolTip="Tooltip.Exclusions.NewProcess"
                                                 KeyDown="TxtNewExclusion_KeyDown" />
                                        <Button Grid.Column="1"
                                                Content="Add Manual"
                                                Tag="Exclusions.AddManual"
                                                Click="BtnAddExclusion_Click"
                                                Margin="0,0,8,0" />
                                        <Button Grid.Column="2"
                                                Content="Remove Selected"
                                                Tag="Exclusions.RemoveSelected"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnRemoveExclusion_Click" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="AUTOMODE" Tag="Exclusions.AutoModeEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock Text="Excluded words" Tag="Exclusions.WordsHeader" Style="{StaticResource SectionHeaderStyle}" />
                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                   Tag="Exclusions.WordsDescription"
                                                   Text="Words in this list are never auto-corrected. Add them in either layout: the opposite layout form is excluded too."
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                    </StackPanel>

                                    <ListBox x:Name="LstExcludedWords"
                                             Grid.Row="1"
                                             Height="88"
                                             Margin="0,0,0,8"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             PreviewMouseWheel="NestedScrollHost_PreviewMouseWheel"
                                             MouseDoubleClick="LstExcludedWords_MouseDoubleClick" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource MutedTextStyle}"
                                               Tag="Exclusions.WordsExamples"
                                               Text="Examples: add either привіт or ghbdsn — both forms will be skipped by Auto Mode."
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8" />

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="TxtNewExcludedWord"
                                                 Grid.Column="0"
                                                 Margin="0,0,10,0"
                                                 ToolTip="Tooltip.Exclusions.NewWord"
                                                 KeyDown="TxtNewExcludedWord_KeyDown" />
                                        <Button Grid.Column="1"
                                                Content="Add Word"
                                                Tag="Exclusions.AddWord"
                                                Click="BtnAddExcludedWord_Click"
                                                Margin="0,0,8,0" />
                                        <Button Grid.Column="2"
                                                Content="Remove Selected"
                                                Tag="Exclusions.RemoveSelected"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnRemoveExcludedWord_Click" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="About" Tag="Tab.About">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="PRODUCT" Tag="About.ProductEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="EN-UA Switcher" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="About.Subtitle"
                                               Text="EN / UA Keyboard Layout Corrector"
                                               Margin="0,0,0,12" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Tag="About.Description"
                                               Text="EN-UA Switcher detects text typed in the wrong keyboard layout and corrects it across native editors, browser inputs and selected fallback paths." />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="TARGETS" Tag="About.TargetsEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Supported contexts" Tag="About.ContextsHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Tag="About.TargetNative"
                                               Text="✓ Notepad, WordPad and other classic Win32 EDIT/RichEdit controls." />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Tag="About.TargetBrowser"
                                               Text="~ Browser inputs and textareas when UI Automation exposes a writable field." />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Tag="About.TargetElectron"
                                               Text="~ Electron apps and many desktop editors via SendInput-based correction paths." />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="SHORTCUTS" Tag="About.ShortcutsEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Safe mode actions" Tag="About.SafeActionsHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Tag="About.LastWordHotkey"
                                               Text="Ctrl+Shift+K — fix last word before caret" />
                                    <TextBlock TextWrapping="Wrap"
                                               Tag="About.SelectionHotkey"
                                               Text="Ctrl+Shift+L — fix selected text" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="CONTACT" Tag="About.ContactEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Author" Tag="About.AuthorHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="stokratt@gmail.com" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="BUILD" Tag="About.BuildEyebrow" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Version" Tag="About.VersionHeader" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock x:Name="TxtAboutVersion"
                                               Style="{StaticResource MutedTextStyle}"
                                               Tag="About.DetectingVersion"
                                               Text="Detecting version..." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="14"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="View Diagnostics"
                        Tag="Action.ViewDiagnostics"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0"
                        Click="BtnDiagnostics_Click" />
                <Button Content="Cancel"
                        Tag="Action.Cancel"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0"
                        Click="BtnCancel_Click" />
                <Button x:Name="BtnSave"
                        Content="Saved"
                        Tag="Action.Saved"
                        IsEnabled="False"
                        Click="BtnSave_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
