<Window x:Class="Switcher.App.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EN-UA Switcher — Diagnostics"
        Width="900" Height="540"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource DarkWindowStyle}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="Clear" Tag="Diagnostics.Clear" Style="{StaticResource SecondaryButtonStyle}"
                        Click="BtnClear_Click" Margin="0,0,6,0" />
                <Button Content="Copy Selected" Tag="Diagnostics.CopySelected" Style="{StaticResource SecondaryButtonStyle}"
                        Click="BtnCopy_Click" Margin="0,0,6,0" />
                <CheckBox x:Name="ChkAutoScroll" Content="Auto-scroll" Tag="Diagnostics.AutoScroll" IsChecked="True"
                          VerticalAlignment="Center" Margin="8,0,0,0" />
                <TextBlock Text="  |  " VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
                <TextBlock x:Name="TxtEntryCount" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
        </Border>

        <!-- Log list -->
        <ListView x:Name="LogList" FontSize="11" FontFamily="Consolas"
                  SelectionMode="Extended">
            <ListView.View>
                <GridView>
                    <GridViewColumn x:Name="ColTime" Header="Time"      Width="75"
                                    DisplayMemberBinding="{Binding TimestampStr}" />
                    <GridViewColumn x:Name="ColProcess" Header="Process"   Width="90"
                                    DisplayMemberBinding="{Binding ProcessName}" />
                    <GridViewColumn x:Name="ColAdapter" Header="Adapter"   Width="90"
                                    DisplayMemberBinding="{Binding ShortAdapter}" />
                    <GridViewColumn x:Name="ColOperation" Header="Operation" Width="90"
                                    DisplayMemberBinding="{Binding Operation}" />
                    <GridViewColumn x:Name="ColOriginal" Header="Original"  Width="200"
                                    DisplayMemberBinding="{Binding OriginalText}" />
                    <GridViewColumn x:Name="ColConverted" Header="Converted" Width="110"
                                    DisplayMemberBinding="{Binding ConvertedText}" />
                    <GridViewColumn x:Name="ColResult" Header="Result"    Width="80"
                                    DisplayMemberBinding="{Binding Result}" />
                    <GridViewColumn x:Name="ColReason" Header="Reason"    Width="500"
                                    DisplayMemberBinding="{Binding Reason}" />
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</Window>
