<Window x:Class="Switcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="EN-UA Switcher — Settings"
        Width="680"
        Height="620"
        MinWidth="620"
        MinHeight="560"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource DarkWindowStyle}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="12"
                Margin="0,0,0,10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="EN-UA Switcher"
                           Style="{StaticResource WindowTitleStyle}"
                           VerticalAlignment="Center" />
                <Border Style="{StaticResource PillBorderStyle}"
                        Margin="12,0,0,0"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Style="{StaticResource StatusDotGreen}" />
                        <TextBlock x:Name="StatusText"
                                   Text="Engine running — Safe mode only"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
            <TabControl Margin="0"
                        Padding="12,12,12,6"
                        Background="Transparent"
                        BorderThickness="0">

                <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="AUTOMATION" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="General" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="Choose how EN-UA Switcher reacts while you type. Safe hotkeys remain available even with Auto Mode disabled."
                                               Margin="0,0,0,8" />

                                    <CheckBox x:Name="ChkAutoMode"
                                              ToolTip="Auto Mode only controls automatic corrections while typing. Safe-mode hotkeys work independently.">
                                        <TextBlock Text="Enable Auto Mode (automatic correction after Space / Enter / Tab)"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkSafeOnlyAutoMode"
                                              Margin="0,6,0,0"
                                              ToolTip="Use only exact-slice safe replacement paths. Browser best-effort auto-replace is skipped.">
                                        <TextBlock Text="Safe-only browser auto-replace (requires Auto Mode)"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkElectronUiaPath"
                                              Margin="0,6,0,0"
                                              ToolTip="Use Backspace+Unicode replacement in Electron apps (VS Code, Slack, Discord, etc.) instead of Shift+Left selection. Avoids race conditions but is experimental.">
                                        <TextBlock Text="Electron app path: UIA read + Backspace replace (requires Auto Mode)"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>

                                    <Separator />

                                    <TextBlock Text="Delimiter keys" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="Choose which keys trigger auto-correction after a word."
                                               Margin="0,0,0,8" />
                                    <CheckBox x:Name="ChkCorrectOnSpace"
                                              Content="Correct on Space"
                                              ToolTip="Trigger auto-correction when Space is pressed." />
                                    <CheckBox x:Name="ChkCorrectOnEnter"
                                              Content="Correct on Enter"
                                              ToolTip="Trigger auto-correction when Enter is pressed." />
                                    <CheckBox x:Name="ChkCorrectOnTab"
                                              Content="Correct on Tab"
                                              ToolTip="Trigger auto-correction when Tab is pressed." />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="CONTROL" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Cancel and undo" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="These options protect the current word buffer and let you roll back an accidental auto-correction."
                                               Margin="0,0,0,8" />

                                    <CheckBox x:Name="ChkCancelOnBackspace"
                                              ToolTip="Pressing Backspace clears the word buffer — no correction will happen.">
                                        <TextBlock Text="Cancel on Backspace" TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkCancelOnLeftArrow"
                                              ToolTip="Pressing Left Arrow clears the word buffer — no correction will happen.">
                                        <TextBlock Text="Cancel on Left Arrow" TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkUndoOnBackspace"
                                              ToolTip="Press Backspace immediately after an auto-correction to revert it.">
                                        <TextBlock Text="Undo correction on Backspace" TextWrapping="Wrap" />
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="APP" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Startup and diagnostics" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="A few practical toggles for startup behavior and troubleshooting."
                                               Margin="0,0,0,8" />

                                    <CheckBox x:Name="ChkRunAtStartup"
                                              Content="Run at Windows startup"
                                              ToolTip="Automatically start EN-UA Switcher when you log in to Windows." />
                                    <CheckBox x:Name="ChkStartMinimized"
                                              Content="Start minimized to system tray" />
                                    <CheckBox x:Name="ChkDiagnostics"
                                              Content="Enable diagnostics logging" />
                                    <CheckBox x:Name="ChkSelectorDiagnosticsExport"
                                              Margin="0,6,0,0"
                                              ToolTip="Writes opt-in structured selector examples for ML analysis to a separate export file.">
                                        <TextBlock Text="Export structured selector examples (opt-in ML diagnostics)"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <CheckBox x:Name="ChkLearnedSelectorGate"
                                              Margin="0,6,0,0"
                                              ToolTip="Keeps heuristics as the primary generator and lets the learned selector reject only low-confidence borderline candidates.">
                                        <TextBlock Text="Enable learned selector rejection gate (experimental)"
                                                   TextWrapping="Wrap" />
                                    </CheckBox>
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Margin="32,6,0,0"
                                               Text="Standard diagnostics stay redacted. Structured selector export writes examples only when you enable it." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Hotkeys">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="SAFE MODE" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Global hotkeys" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="These hotkeys act on the focused text target even if Auto Mode is turned off."
                                               Margin="0,0,0,8" />
                                    <TextBlock x:Name="TxtHotkeyStatus"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="Hotkeys status: checking..."
                                               Margin="0,0,0,14" />

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Fix last word" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 x:Name="TxtLastWordHotkey"
                                                 IsReadOnly="True"
                                                 ToolTip="Click here, then press your key combination (e.g. Ctrl+Shift+K). At least one modifier required."
                                                 PreviewKeyDown="TxtHotkey_PreviewKeyDown" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Fix selected text" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1"
                                                 x:Name="TxtSelectionHotkey"
                                                 IsReadOnly="True"
                                                 ToolTip="Click here, then press your key combination (e.g. Ctrl+Shift+L). At least one modifier required."
                                                 PreviewKeyDown="TxtHotkey_PreviewKeyDown" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="NOTE" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Current behavior" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="Click a hotkey field and press your desired combination (modifier + letter/key). At least one of Ctrl, Shift, or Alt is required. Changes take effect after Save." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Exclusions">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="SCOPE" Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock Text="Excluded processes" Style="{StaticResource SectionHeaderStyle}" />
                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                    Text="Choose a running app from the list or type a process name manually. Use names without .exe."
                                                   Margin="0,0,0,6" />
                                    </StackPanel>

                                    <Grid Grid.Row="1" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox x:Name="CmbRunningProcesses"
                                                   Grid.Column="0"
                                                   Margin="0,0,10,0"
                                                   IsEditable="True"
                                                   IsTextSearchEnabled="True"
                                                   StaysOpenOnEdit="True"
                                                   ToolTip="Click to choose a running process"
                                                   GotKeyboardFocus="CmbRunningProcesses_GotKeyboardFocus"
                                                   PreviewMouseLeftButtonDown="CmbRunningProcesses_PreviewMouseLeftButtonDown"
                                                   PreviewMouseWheel="NestedScrollHost_PreviewMouseWheel" />
                                        <Button Grid.Column="1"
                                                Content="Add Selected"
                                                Click="BtnAddSuggestedExclusion_Click"
                                                Margin="0,0,8,0" />
                                        <Button Grid.Column="2"
                                                Content="Refresh"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnRefreshProcesses_Click" />
                                    </Grid>

                                    <ListBox x:Name="LstExclusions"
                                             Grid.Row="2"
                                             Height="96"
                                             Margin="0,0,0,8"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             PreviewMouseWheel="NestedScrollHost_PreviewMouseWheel"
                                             MouseDoubleClick="LstExclusions_MouseDoubleClick" />

                                    <TextBlock Grid.Row="3"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="Manual add: type a name like chrome, telegram, element or codex and press Enter."
                                               Margin="0,0,0,8" />

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="TxtNewExclusion"
                                                 Grid.Column="0"
                                                 Margin="0,0,10,0"
                                                 ToolTip="e.g. chrome, notepad, code"
                                                 KeyDown="TxtNewExclusion_KeyDown" />
                                        <Button Grid.Column="1"
                                                Content="Add Manual"
                                                Click="BtnAddExclusion_Click"
                                                Margin="0,0,8,0" />
                                        <Button Grid.Column="2"
                                                Content="Remove Selected"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnRemoveExclusion_Click" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="AUTOMODE" Style="{StaticResource EyebrowTextStyle}" />
                                        <TextBlock Text="Excluded words" Style="{StaticResource SectionHeaderStyle}" />
                                        <TextBlock Style="{StaticResource MutedTextStyle}"
                                                   Text="Words in this list are never auto-corrected. Add them in either layout: the opposite layout form is excluded too."
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,6" />
                                    </StackPanel>

                                    <ListBox x:Name="LstExcludedWords"
                                             Grid.Row="1"
                                             Height="88"
                                             Margin="0,0,0,8"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             PreviewMouseWheel="NestedScrollHost_PreviewMouseWheel"
                                             MouseDoubleClick="LstExcludedWords_MouseDoubleClick" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="Examples: add either привіт or ghbdsn — both forms will be skipped by Auto Mode."
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,8" />

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox x:Name="TxtNewExcludedWord"
                                                 Grid.Column="0"
                                                 Margin="0,0,10,0"
                                                 ToolTip="e.g. привіт or ghbdsn"
                                                 KeyDown="TxtNewExcludedWord_KeyDown" />
                                        <Button Grid.Column="1"
                                                Content="Add Word"
                                                Click="BtnAddExcludedWord_Click"
                                                Margin="0,0,8,0" />
                                        <Button Grid.Column="2"
                                                Content="Remove Selected"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnRemoveExcludedWord_Click" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="About">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,10,2,0">
                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="PRODUCT" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="EN-UA Switcher" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="EN / UA Keyboard Layout Corrector"
                                               Margin="0,0,0,12" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="EN-UA Switcher detects text typed in the wrong keyboard layout and corrects it across native editors, browser inputs and selected fallback paths." />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="TARGETS" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Supported contexts" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="✓ Notepad, WordPad and other classic Win32 EDIT/RichEdit controls." />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="~ Browser inputs and textareas when UI Automation exposes a writable field." />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="~ Electron apps and many desktop editors via SendInput-based correction paths." />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="SHORTCUTS" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Safe mode actions" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                               Text="Ctrl+Shift+K — fix last word before caret" />
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Ctrl+Shift+L — fix selected text" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="CONTACT" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Author" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}"
                                               Text="stokratt@gmail.com" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SubtleCardBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="BUILD" Style="{StaticResource EyebrowTextStyle}" />
                                    <TextBlock Text="Version" Style="{StaticResource SectionHeaderStyle}" />
                                    <TextBlock x:Name="TxtAboutVersion"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="Detecting version..." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="14"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="View Diagnostics"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0"
                        Click="BtnDiagnostics_Click" />
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0"
                        Click="BtnCancel_Click" />
                <Button x:Name="BtnSave"
                        Content="Saved"
                        IsEnabled="False"
                        Click="BtnSave_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
